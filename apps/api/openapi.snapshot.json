            },
            "description": "Successful Response"
          },
          "400": {
            "description": "Bad request \u2014 invalid input"
          },
          "401": {
            "description": "Not authenticated"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "List Devices",
        "tags": [
          "devices"
        ]
      }
    },
