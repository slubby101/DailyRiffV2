  "info": {
    "title": "DailyRiff API",
    "version": "0.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/account-access-log": {
      "get": {
        "description": "Return the Account Access Log for the authenticated user.\n\nShows every admin impersonation session that targeted this user,\nincluding playback counts from impersonation_playback_log.\nRead-only \u2014 available on the user's settings page.",
        "operationId": "get_account_access_log_account_access_log_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AccountAccessLogEntry"
                  },
                  "title": "Response Get Account Access Log Account Access Log Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "description": "Bad request \u2014 invalid input"
          },
          "401": {
            "description": "Not authenticated"
          },
          "405": {
            "description": "Method not allowed"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Get Account Access Log",
        "tags": [
          "account-access-log"
        ]
      }
    },
    "/admin/beta/feedback": {
      "get": {
        "description": "List all beta feedback across studios (superadmin only).",
        "operationId": "list_all_beta_feedback_admin_beta_feedback_get",
        "parameters": [
          {
            "in": "query",
            "name": "category",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "bug",
                    "feature_request",
                    "usability",
                    "performance",
                    "other"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Category"
            }
          },
          {
            "in": "query",
            "name": "severity",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "critical",
                    "high",
                    "medium",
                    "low"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Severity"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/BetaFeedbackResponse"
                  },
                  "title": "Response List All Beta Feedback Admin Beta Feedback Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "description": "Bad request \u2014 invalid input"
          },
          "401": {
            "description": "Not authenticated"
          },
          "403": {
            "description": "Superadmin role required"
          },
          "405": {
            "description": "Method not allowed"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "List All Beta Feedback",
        "tags": [
          "admin-beta"
        ]
      }
    },
    "/admin/beta/feedback/{feedback_id}/resolve": {
      "post": {
        "description": "Mark beta feedback as resolved (superadmin only).",
        "operationId": "resolve_beta_feedback_admin_beta_feedback__feedback_id__resolve_post",
        "parameters": [
          {
            "in": "path",
            "name": "feedback_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Feedback Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BetaFeedbackResolveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BetaFeedbackResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "description": "Bad request \u2014 invalid input"
          },
