{
  "name": "@dailyriff/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "openapi-ts -i ../../apps/api/openapi.snapshot.json -o src -p @hey-api/typescript",
